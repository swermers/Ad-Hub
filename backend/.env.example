ANTHROPIC_API_KEY=sk-ant-...
DATABASE_URL=sqlite:///./adhub.db
CORS_ORIGINS=["http://localhost:3000"]

# X/Twitter API (optional — needed for Twitter posting)
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
TWITTER_BEARER_TOKEN=

# Meta/Facebook Ads API (optional — needed for Meta posting)
META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=

# Scheduler
SCHEDULER_ENABLED=true
SCHEDULER_INTERVAL_MINUTES=1
METRICS_COLLECTION_INTERVAL_MINUTES=60
